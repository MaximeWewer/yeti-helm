{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "yeti chart values",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "image": {
      "type": "object",
      "properties": {
        "registry": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "imagePullSecrets": { "type": "array" },
    "frontend": { "type": "object" },
    "api": { "type": "object" },
    "tasks": { "type": "object" },
    "events": { "type": "object", "properties": { "enabled": { "type": "boolean" } } },
    "beats": { "type": "object", "properties": { "enabled": { "type": "boolean" } } },
    "agents": { "type": "object", "properties": { "enabled": { "type": "boolean" } } },
    "bloomcheck": { "type": "object", "properties": { "enabled": { "type": "boolean" } } },
    "exports": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "existingClaim": { "type": "string" },
        "storageClass": { "type": "string" },
        "size": { "type": "string" },
        "accessModes": { "type": "array" },
        "mountPath": { "type": "string" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "existingSecret": { "type": "string" },
        "secrets": {
          "type": "object",
          "properties": {
            "yetiSecret": { "type": "string" },
            "yetiUser": { "type": "string" },
            "arangoPassword": { "type": "string" }
          }
        },
        "yetiConf": { "type": "string" },
        "confMergeImage": { "type": "string" },
        "createUser": { "type": "boolean" },
        "auth": { "type": "object" },
        "system": {
          "type": "object",
          "properties": {
            "exportPath": { "type": "string" },
            "pluginsPath": { "type": "string" },
            "logging": { "type": "string" },
            "auditLogfile": { "type": "string" },
            "templateDir": { "type": "string" }
          }
        },
        "rbac": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "defaultGlobalRole": { "type": "string", "enum": ["writer", "reader"] },
            "defaultAcls": { "type": "string" }
          }
        },
        "tag": { "type": "object", "properties": { "defaultExpiration": { "type": "string" } } },
        "chromadb": { "type": "object", "properties": { "path": { "type": "string" } } },
        "events": { "type": "object" },
        "proxy": {
          "type": "object",
          "properties": { "http": { "type": "string" }, "https": { "type": "string" } }
        },
        "timesketch": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "endpoint": { "type": "string" },
            "existingSecret": { "type": "string" },
            "usernameKey": { "type": "string" },
            "passwordKey": { "type": "string" }
          }
        },
        "oidc": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "discoveryUrl": { "type": "string" },
            "allowedExtraAudiences": { "type": "string" },
            "existingSecret": { "type": "string" }
          }
        }
      }
    },
    "arangodb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "database": { "type": "string" },
        "rootPasswordExistingSecret": { "type": "string" },
        "image": { "type": "string" },
        "mode": { "type": "string", "enum": ["Single", "ActiveFailover", "Cluster"] },
        "persistence": { "type": "object" },
        "resources": { "type": "object" }
      }
    },
    "redis": { "type": "object", "properties": { "enabled": { "type": "boolean" } } },
    "externalRedis": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer" }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "scrapeAnnotations": { "type": "boolean" },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string" },
            "interval": { "type": "string" },
            "scrapeTimeout": { "type": "string" },
            "labels": { "type": "object" },
            "annotations": { "type": "object" },
            "honorLabels": { "type": "boolean" },
            "relabelings": { "type": "array" },
            "metricRelabelings": { "type": "array" }
          }
        },
        "frontend": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "type": "object" },
            "port": { "type": "integer" },
            "statusPort": { "type": "integer" },
            "resources": { "type": "object" }
          }
        },
        "celery": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "type": "object" },
            "port": { "type": "integer" },
            "workerTaskEvents": { "type": "boolean" },
            "extraArgs": { "type": "array" },
            "resources": { "type": "object" }
          }
        },
        "arangodb": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "port": { "type": "integer" }
          }
        },
        "networkPolicy": {
          "type": "object",
          "properties": { "allowedFrom": { "type": "array" } }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "podSecurityContext": { "type": "object" },
    "containerSecurityContext": { "type": "object" },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "host": { "type": "string" },
        "tls": { "type": "array" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "frontendAllowedFrom": { "type": "array" },
        "extraEgress": { "type": "array" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["string", "integer"] },
        "maxUnavailable": { "type": ["string", "integer"] }
      }
    },
    "extraEnv": { "type": "array" },
    "extraEnvFrom": { "type": "array" }
  }
}
